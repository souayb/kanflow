rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Projects (minimal schema for relational sync)
    match /projects/{projectId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidId(projectId);
    }

    // Chat Messages
    match /projects/{projectId}/messages/{messageId} {
      function isValidChatMessage(data) {
        let coreKeys = ['projectId', 'userId', 'userName', 'content', 'createdAt', 'type'];
        return data.keys().hasAll(coreKeys)
          && (data.keys().size() >= 6 && data.keys().size() <= 7)
          && data.projectId == projectId
          && data.userId == request.auth.uid
          && data.userName is string && data.userName.size() <= 100
          && data.content is string && data.content.size() <= 5000
          && data.type in ['user', 'ai']
          && data.createdAt == request.time;
      }

      allow list: if isSignedIn(); // Queries filtered by projectId in path
      allow create: if isSignedIn() 
        && isValidId(messageId)
        && isValidChatMessage(incoming())
        && exists(/databases/$(database)/documents/projects/$(projectId));
      
      // Messages are typically immutable in this context
      allow update, delete: if false;
    }
  }
}
