# Ollama — local LLM inference (no API key required)
# URL of the Ollama server. Use http://localhost:11434 for local dev,
# or http://ollama:11434 when running inside Docker Compose.
VITE_OLLAMA_URL="http://localhost:11434"

# Ollama model to use for all AI features.
# Run `ollama pull <model>` or let docker-compose auto-pull on first start.
# Good options: llama3.2, mistral, qwen2.5, gemma3
VITE_OLLAMA_MODEL="llama3.2"

# APP_URL: The URL where this app is hosted (used for self-referential links).
APP_URL="http://localhost:3000"
