# Ollama — local LLM inference (no API key required).
#
# When unset (recommended for `npm run dev`):
#   the app uses same-origin `/ollama`, which Vite proxies to http://127.0.0.1:11434.
#
# Docker Compose build passes VITE_OLLAMA_URL=/ollama so nginx proxies to the ollama service.
#
# To call Ollama directly from the browser (requires permissive OLLAMA_ORIGINS), use:
# VITE_OLLAMA_URL="http://localhost:11434"

VITE_OLLAMA_MODEL="llama3.2"

# Keycloak — identity provider for login/logout.
# Run `docker compose up keycloak` or point to your own Keycloak instance.
VITE_KEYCLOAK_URL="http://localhost:8180"
VITE_KEYCLOAK_REALM="kanflow"
VITE_KEYCLOAK_CLIENT_ID="kanflow-frontend"

# APP_URL: The URL where this app is hosted (used for self-referential links).
APP_URL="http://localhost:3000"
