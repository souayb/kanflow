# --- Kanflow Rust API ---
DATABASE_URL=postgresql://kanflow:kanflow@localhost:5432/kanflow
MONGO_URI=mongodb://localhost:27017
MONGO_DB=kanflow
KANFLOW_HOST=0.0.0.0
KANFLOW_PORT=8080

# --- Ollama (local LLM) ---
# Model to auto-pull on docker compose up (also used by ollama-pull service)
OLLAMA_MODEL=llama3.2
